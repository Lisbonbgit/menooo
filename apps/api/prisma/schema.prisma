// ============================================================================
// Comanda — Prisma schema
// SaaS multi-tenant de encomendas online para restaurantes.
// Estratégia multi-tenancy: shared database, isolamento por `tenantId` em
// cada linha. Cada restaurante = um Tenant (com `slug` para a loja pública).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum TenantStatus {
  PENDING // registado, ainda não ativado
  ACTIVE
  SUSPENDED // suspenso (ex.: falta de pagamento)
  CLOSED
}

// estado da conta do dono (empresa): banida = login e lojas bloqueados
enum AccountStatus {
  ACTIVE
  BANNED
}

enum PlanType {
  FREE
  PRO
}

enum UserRole {
  SUPER_ADMIN // dono da plataforma (sem tenant)
  OWNER // dono do restaurante
  STAFF // funcionário do restaurante
  KITCHEN // tablet de cozinha emparelhado a UMA unidade (só pedidos)
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum OrderType {
  DELIVERY // entrega ao domicílio
  PICKUP // take-away / levantamento
}

enum OrderStatus {
  PENDING // recebido, aguarda aceitação do restaurante
  ACCEPTED // aceite pelo restaurante
  PREPARING // em preparação
  READY // pronto (para levantamento/entrega)
  OUT_FOR_DELIVERY // a caminho
  COMPLETED // entregue / concluído
  REJECTED // recusado pelo restaurante
  CANCELLED // cancelado
}

enum PaymentMethod {
  CASH // dinheiro à porta/balcão
  CARD_ON_DELIVERY // multibanco/cartão na entrega
  MBWAY // MB WAY online
  CARD_ONLINE // cartão online
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENT // desconto em percentagem do subtotal
  FIXED // desconto de valor fixo
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW // liberta a mesa para o resto da janela (disponibilidade só conta CONFIRMED)
}

enum MenuType {
  DELIVERY // menu da loja online (entrega + levantamento) — o atual
  DINE_IN  // menu servido ao cliente à mesa (via QR, Fase 2)
}

// ----------------------------------------------------------------------------
// Tenant (restaurante)
// ----------------------------------------------------------------------------

// Conta do dono — detém a subscrição, agrupa várias unidades (restaurantes).
// "Uma subscrição cobre todas as unidades da conta."
model Account {
  id                   String        @id @default(cuid())
  name                 String
  status               AccountStatus @default(ACTIVE)
  bannedAt             DateTime? // quando foi banida (null = nunca)
  referralSource       String? // "como nos conheceste?" respondido no registo
  // subscrição PARTILHADA por todas as unidades da conta
  activatedAt          DateTime? // 1ª ativação pelo admin (arranca os 7 dias de teste)
  trialEndsAt          DateTime? // fim do período de teste
  trialReminderSentAt  DateTime? // aviso de fim de teste já enviado (evita repetir)
  paidUntil            DateTime? // subscrição paga até esta data (estendida por pagamentos)
  lifetimeAccess       Boolean       @default(false) // acesso permanente dado pelo super-admin
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?

  users    User[]
  tenants  Tenant[]
  payments SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Tenant (restaurante / unidade)
// ----------------------------------------------------------------------------

model Tenant {
  id         String       @id @default(cuid())
  accountId  String // conta do dono (subscrição partilhada por várias unidades)
  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  slug       String       @unique // usado na loja pública: /loja/{slug}
  name       String
  logoUrl    String? // logótipo da loja (identidade na montra)
  coverUrl   String? // foto de capa da loja (topo da montra)
  brandColor String? // cor da marca na montra (hex #rrggbb); null = laranja Menooo
  heroColor  String? // cor do topo/cabeçalho da montra (hex); null = espresso
  status     TenantStatus @default(PENDING)
  plan       PlanType     @default(FREE)

  // contacto / morada
  email   String?
  phone   String?
  address String?
  city    String?
  zipCode String?

  // definições de loja
  currency        String  @default("EUR")
  timezone        String  @default("Europe/Lisbon")
  acceptsDelivery Boolean @default(true)
  acceptsPickup   Boolean @default(true)
  deliveryFee     Decimal @default(0) @db.Decimal(10, 2)
  minOrderValue   Decimal @default(0) @db.Decimal(10, 2)
  isOpen          Boolean @default(false) // toggle manual de aberto/fechado

  // emparelhamento do tablet de cozinha (código de uso-único, ver spec app-cozinha)
  kitchenPairId        String?   @unique // parte pública do código (lookup indexado)
  kitchenPairHash      String? // argon2 do segredo do código
  kitchenPairExpiresAt DateTime?
  kitchenPairAttempts  Int       @default(0)
  kitchenPairedAt      DateTime? // último emparelhamento bem-sucedido

  // reservas de mesas
  reservationsEnabled       Boolean @default(false)
  reservationDurationMin    Int     @default(120)
  reservationBufferMin      Int     @default(0) // limpeza/turnover entre reservas
  reservationMinNoticeMin   Int     @default(60)
  reservationMaxAdvanceDays Int     @default(30)
  reservationMaxPartySize   Int     @default(12) // só canal ONLINE
  reservationGraceMin       Int     @default(15) // tolerância de atraso: só comunica, não liberta a mesa

  categories          Category[]
  products            Product[]
  orders              Order[]
  openingHours        OpeningHour[]
  deliveryZones       DeliveryZone[]
  coupons             Coupon[]
  modifierGroups      ModifierGroup[]
  menus               Menu[]
  tables              Table[]
  dineTables          DineTable[]
  reservations        Reservation[]
  reservationWindows  ReservationWindow[] // EXPAND: substituída pela ReservationService; o DROP fica para um ciclo posterior
  reservationServices ReservationService[]
  reservationBlocks   ReservationBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([accountId])
}

// pagamento de subscrição registado pelo admin (a receita da plataforma).
// Sobrevive à exclusão da conta: accountId fica null e accountName guarda o nome.
model SubscriptionPayment {
  id          String   @id @default(cuid())
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountName String? // snapshot do nome da empresa no momento do pagamento
  amount      Decimal  @db.Decimal(10, 2) // valor recebido (€)
  months      Int      @default(1) // meses de subscrição adicionados
  note        String? // ex.: "transferência", "MB WAY", nº de fatura

  createdAt DateTime @default(now())

  @@index([accountId])
}

// zona de entrega: prefixo de código postal -> taxa + mínimo próprios
model DeliveryZone {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  postalPrefix String // ex.: "1000" cobre 1000-xxx
  fee          Decimal @default(0) @db.Decimal(10, 2)
  minOrder     Decimal @default(0) @db.Decimal(10, 2)
  active       Boolean @default(true)

  @@index([tenantId])
}

// cupão de desconto
model Coupon {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String // normalizado em maiúsculas
  type      CouponType @default(PERCENT)
  value     Decimal    @db.Decimal(10, 2) // % (0-100) ou valor fixo
  minOrder  Decimal    @default(0) @db.Decimal(10, 2)
  active    Boolean    @default(true)
  expiresAt DateTime?
  maxUses   Int? // null = ilimitado
  usedCount Int        @default(0)

  createdAt DateTime @default(now())

  @@unique([tenantId, code])
  @@index([tenantId])
}

// horário de funcionamento — uma faixa por dia da semana (0=Dom … 6=Sáb)
model OpeningHour {
  id          String @id @default(cuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  weekday     Int // 0..6
  openMinute  Int // minutos desde a meia-noite (ex.: 12:00 = 720)
  closeMinute Int // ex.: 23:00 = 1380

  @@unique([tenantId, weekday])
}

// ----------------------------------------------------------------------------
// Utilizadores
// ----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  accountId    String? // null => SUPER_ADMIN (plataforma); senão dono/staff da conta
  account      Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  role         UserRole   @default(OWNER)
  status       UserStatus @default(ACTIVE)

  // verificação de email (código de 6 dígitos no registo)
  emailVerifiedAt           DateTime? // null = por verificar
  verificationCodeHash      String? // hash do código de 6 dígitos
  verificationCodeExpiresAt DateTime?
  verificationAttempts      Int       @default(0)

  // reposição de password ("esqueci-me") — código de 6 dígitos por email
  passwordResetCodeHash  String?
  passwordResetExpiresAt DateTime?
  passwordResetAttempts  Int       @default(0)

  // papel KITCHEN: unidade a que o tablet está preso (null para os outros papéis)
  kitchenTenantId String?

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, email]) // email único por conta
  @@index([email])
  @@index([kitchenTenantId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Catálogo (menu)
// ----------------------------------------------------------------------------

// menu da loja: Delivery (loja online) ou Sala (dine-in via QR, Fase 2). Um por (tenant, tipo).
model Menu {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      MenuType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories     Category[]
  modifierGroups ModifierGroup[]

  @@unique([tenantId, type])
  @@index([tenantId])
}

model Category {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuId    String
  menu      Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([menuId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  vatRate     Int      @default(23) // taxa de IVA (%) incluída no preço: 23/13/6/0
  imageUrl    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)

  modifierGroupLinks ProductModifierGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([categoryId])
}

// grupo de opções reutilizável (ex.: "Tamanho", "Extras") — pertence ao
// restaurante e anexa-se a produtos via ProductModifierGroup
model ModifierGroup {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuId    String
  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name      String
  required  Boolean    @default(false)
  minSelect Int        @default(0)
  maxSelect Int        @default(1)
  modifiers Modifier[]

  productLinks ProductModifierGroup[]

  @@index([tenantId])
  @@index([menuId])
}

// liga um grupo reutilizável a um produto (com ordem por produto)
model ProductModifierGroup {
  id        String        @id @default(cuid())
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder Int           @default(0)

  @@unique([productId, groupId])
  @@index([productId])
  @@index([groupId])
}

// opção individual (ex.: "Grande +1.50")
model Modifier {
  id         String        @id @default(cuid())
  groupId    String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceDelta Decimal       @default(0) @db.Decimal(10, 2)
  sortOrder  Int           @default(0)
}

// ----------------------------------------------------------------------------
// Encomendas
// ----------------------------------------------------------------------------

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number     Int // número sequencial por tenant (legível)
  trackToken String      @unique @default(cuid()) // link privado de acompanhamento do pedido
  status     OrderStatus @default(PENDING)
  type       OrderType   @default(DELIVERY)

  // cliente (sem conta — checkout de convidado)
  customerName     String
  customerPhone    String
  customerEmail    String?
  marketingConsent Boolean @default(false) // aceita receber comunicações de marketing

  // entrega
  deliveryAddress String?
  deliveryCity    String?
  deliveryZipCode String?
  notes           String?

  // agendamento: null = "para já"; senão a hora escolhida pelo cliente
  scheduledFor DateTime?

  // valores
  subtotal    Decimal @default(0) @db.Decimal(10, 2)
  deliveryFee Decimal @default(0) @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  couponCode  String?
  total       Decimal @default(0) @db.Decimal(10, 2)
  vatTotal    Decimal @default(0) @db.Decimal(10, 2) // IVA incluído no total

  // pagamento
  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PENDING)
  changeFor     Decimal?      @db.Decimal(10, 2) // dinheiro: troco para este valor

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String? // snapshot — produto pode ser apagado depois
  name      String // nome no momento da encomenda
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2) // preço base + modifiers, por unidade
  total     Decimal @db.Decimal(10, 2)
  vatRate   Int     @default(23) // taxa de IVA (%) do produto, no momento da encomenda

  modifiers OrderItemModifier[]

  @@index([orderId])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  name        String
  priceDelta  Decimal   @default(0) @db.Decimal(10, 2)
}

// ----------------------------------------------------------------------------
// Reservas de Mesas
// ----------------------------------------------------------------------------

model Table {
  id             String             @id @default(cuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  area           String? // juntar só dentro da mesma área não-nula
  seats          Int
  joinable       Boolean            @default(false)
  bookableOnline Boolean            @default(true) // false = só atribuível em reservas MANUAL
  active         Boolean            @default(true)
  sortOrder      Int                @default(0)
  x              Int? // coluna no mapa de sala (0..7); null = ainda não colocada
  y              Int? // linha no mapa de sala; null = ainda não colocada
  shape          String             @default("square") // 'square' | 'round' — só leitura visual
  reservations   ReservationTable[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([tenantId])
}

// mesas de sala (dine-in QR) — separadas das mesas de reservas (Table): sem seats/área/mapa,
// identificadas por um qrToken único que o storefront resolve publicamente (ver DineTablesService).
model DineTable {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  qrToken   String   @unique @default(cuid())
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Reservation {
  id               String             @id @default(cuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code             String             @unique // base32 6 chars; P2002 → re-gerar (padrão kitchenPairCode)
  cancelTokenHash  String? // sha256 hex do token (NÃO argon2 — token tem 256 bits, ver §7)
  status           ReservationStatus  @default(CONFIRMED)
  source           String             @default("ONLINE") // ONLINE | MANUAL
  partySize        Int
  startsAt         DateTime // UTC
  endsAt           DateTime // UTC — materializado (inclui duração; o buffer soma-se NA QUERY)
  customerName     String
  customerPhone    String
  customerEmail    String? // obrigatório ONLINE; opcional MANUAL
  // Chaves normalizadas SÓ para o cap anti-spam por contacto (ver contact.util.ts).
  // Os campos acima mantêm-se crus, para exibição.
  contactEmailKey  String? // trim + lowercase
  contactPhoneKey  String? // só dígitos, últimos 9
  notes            String?
  marketingConsent Boolean            @default(false) // consistente com Order (registo RGPD)
  cancelledBy      String? // CUSTOMER | RESTAURANT
  tables           ReservationTable[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tenantId, startsAt])
  @@index([tenantId, contactEmailKey])
  @@index([tenantId, contactPhoneKey])
}

model ReservationTable {
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([reservationId, tableId])
  @@index([tableId])
}

/// Janela de SEATING para reservas (até 2 por weekday, imposto no service).
/// Sem janelas definidas para um weekday → fallback ao OpeningHour desse dia.
/// SUBSTITUÍDA pela ReservationService (R4). Fica de pé de propósito: o código deixa de a ler,
/// mas o DROP só acontece num ciclo posterior, depois de a R4 estar provada em produção — assim
/// um rollback de imagem para a R3 ainda encontra a tabela que lê.
model ReservationWindow {
  id          String @id @default(cuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  weekday     Int // 0=domingo … 6=sábado (mesma convenção do OpeningHour)
  openMinute  Int
  closeMinute Int // último slot COMEÇA em closeMinute (janela de seating, não de estadia)

  @@index([tenantId, weekday])
}

/// Serviço com nome ("Almoço", "Jantar") e os dias em que corre. Sucede à ReservationWindow:
/// um serviço traz vários weekdays, em vez de uma linha por dia.
model ReservationService {
  id          String @id @default(cuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String // livre — é o dono que decide
  weekdays    Int[] // 0=domingo … 6=sábado (mesma convenção do OpeningHour)
  openMinute  Int
  closeMinute Int // último slot COMEÇA em closeMinute (janela de seating, não de estadia)
  sortOrder   Int    @default(0)

  @@index([tenantId])
}

/// Dia inteiro sem reservas online (feriado, evento privado, "pausar hoje").
model ReservationBlock {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date      String // YYYY-MM-DD na timezone do tenant (dia LOCAL)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([tenantId, date])
}
