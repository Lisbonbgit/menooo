# ============================================================================
# Menooo — produção (copiar para .env no servidor e preencher).
# Acesso por IP:porta enquanto não há domínio.
# Gerar segredos: openssl rand -hex 32
# ============================================================================

# Base de dados (interna ao docker compose)
POSTGRES_PASSWORD=trocar-por-password-forte

# Segredos JWT (gerar com: openssl rand -hex 32)
JWT_ACCESS_SECRET=trocar-access
JWT_REFRESH_SECRET=trocar-refresh

# URL pública da API — EMBEBIDA no bundle do cliente no build.
# Se mudares de IP/porta/domínio, é preciso reconstruir as apps.
NEXT_PUBLIC_API_URL=http://187.124.4.163:8083

# Origens permitidas (storefront, dashboard, admin) para CORS + WebSocket
CORS_ORIGINS=http://187.124.4.163:8080,http://187.124.4.163:8081,http://187.124.4.163:8082

# --- Stripe (cobrança mensal automática) ---
# 1) Cria conta em stripe.com  2) corre: node apps/api/scripts/stripe-setup.mjs
# Vazios = modo manual (admin regista pagamentos à mão)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
DASHBOARD_URL=http://187.124.4.163:8081

# --- Email transacional (Resend por SMTP) ---
# Verifica o domínio menooo.com em resend.com/domains para enviar de noreply@menooo.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx
MAIL_FROM=Menooo <noreply@menooo.com>
STORE_URL=https://menooo.com
