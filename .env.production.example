# ============================================================================
# Menooo — produção (copiar para .env no servidor e preencher).
# Produção corre em https://*.menooo.com, atrás de Caddy (Let's Encrypt).
# Gerar segredos: openssl rand -hex 32
# ============================================================================

# Base de dados (interna ao docker compose)
POSTGRES_PASSWORD=trocar-por-password-forte

# Segredos JWT (gerar com: openssl rand -hex 32)
JWT_ACCESS_SECRET=trocar-access
JWT_REFRESH_SECRET=trocar-refresh

# Cozinha (tablet emparelhado) — TTLs mais curtos; defaults no código se ausentes
# KITCHEN_ACCESS_TTL=5m
# KITCHEN_REFRESH_TTL=5d

# URL pública da API — EMBEBIDA no bundle do cliente no build.
# Se mudares de IP/porta/domínio, é preciso reconstruir as apps.
NEXT_PUBLIC_API_URL=https://api.menooo.com

# Também embebidas no bundle no build. NÃO as deixes por definir: o compose
# passa-as como string VAZIA, e o `??` do código só apanha null/undefined —
# o storefront rebenta em `new URL('')` e o build da imagem inteira falha.
NEXT_PUBLIC_STORE_URL=https://menooo.com
NEXT_PUBLIC_DASHBOARD_URL=https://painel.menooo.com

# Base pública onde a API serve as imagens carregadas (fotos/capa/logótipo).
# Normalmente igual ao NEXT_PUBLIC_API_URL mas SEM /api (ex.: https://api.menooo.com).
PUBLIC_API_URL=https://api.menooo.com

# Origens permitidas (storefront, dashboard, admin) para CORS + WebSocket
CORS_ORIGINS=https://menooo.com,https://www.menooo.com,https://painel.menooo.com,https://admin.menooo.com

# Gestor master (super-admin de admin.menooo.com). Se definidos, a API garante
# este login em cada arranque. Muda aqui e reinicia a api para trocar o login.
SUPER_ADMIN_EMAIL=admin@menooo.pt
SUPER_ADMIN_PASSWORD=troca-por-uma-password-forte

# --- Stripe (cobrança mensal automática) ---
# 1) Cria conta em stripe.com  2) corre: node apps/api/scripts/stripe-setup.mjs
# Vazios = modo manual (admin regista pagamentos à mão)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
DASHBOARD_URL=http://187.124.4.163:8081

# --- Email transacional (Resend por SMTP) ---
# Verifica o domínio menooo.com em resend.com/domains para enviar de noreply@menooo.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx
MAIL_FROM=Menooo <noreply@menooo.com>
# avisos internos da plataforma (novos registos); vazio = geral@lisbonb.com
PLATFORM_NOTIFY_EMAIL=geral@lisbonb.com
ADMIN_URL=https://admin.menooo.com
STORE_URL=https://menooo.com
