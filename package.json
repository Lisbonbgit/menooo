{
  "name": "comanda",
  "version": "0.1.0",
  "private": true,
  "description": "Comanda — Plataforma SaaS de encomendas online para restaurantes (multi-tenant)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @comanda/api prisma:generate",
    "db:migrate": "pnpm --filter @comanda/api prisma:migrate",
    "db:seed": "pnpm --filter @comanda/api prisma:seed",
    "db:studio": "pnpm --filter @comanda/api prisma:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
