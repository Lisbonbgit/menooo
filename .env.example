# ============================================================
# Menoo — variáveis de ambiente (copiar para .env)
# ============================================================

# --- Base de dados ---
DATABASE_URL="postgresql://comanda:comanda@localhost:5433/comanda?schema=public"

# --- API ---
API_PORT=3001
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET="troca-isto-em-producao-access"
JWT_REFRESH_SECRET="troca-isto-em-producao-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS — origens permitidas (storefront, dashboard, admin)
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# --- Frontends ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
